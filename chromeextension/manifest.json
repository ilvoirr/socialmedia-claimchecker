{
  "manifest_version": 3,
  "name": "Claim Radar",
  "version": "1.0.0",
  "description": "Fact-check any claim or screenshot instantly.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": { 
      "16": "icons/icon16.png",
      "48": "icons/icon48.png", 
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": [
    "https://socialmedia-claimchecker.vercel.app/*",
    "https://socialmedia-claimchecker.onrender.com/*"
  ]
}
